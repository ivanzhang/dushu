---
import { getCollection } from 'astro:content';
import ReadingDashboard from '../components/ReadingDashboard.astro';
import Base from '../layouts/Base.astro';
import { buildEpubDownloadPath } from '../lib/epub';
import {
  buildBookCollectionMaps,
  buildBookDisplayMaps,
  pickPlannedBooks,
} from '../lib/library';

const books = await getCollection('books');
const chapters = await getCollection('chapters');
const { tierLabelMap, completionLevelMap } = buildBookDisplayMaps(books);
const { collectionProgressMap, collectionDepthMap, collectionStatusMap } = buildBookCollectionMaps(books, chapters);
const deepReadingBooks = pickPlannedBooks(books, ['hongloumeng', 'sanguoyanyi', 'xiyouji']);

const bookMetaList = books.map((book) => ({
  slug: book.id,
  title: book.data.title,
  author: book.data.author,
  summary: book.data.summary,
  wordCount: book.data.wordCount,
  tierLabel: tierLabelMap[book.id],
  completionLevel: completionLevelMap[book.id],
  collectionStatusText: collectionStatusMap[book.id],
  collectionProgressText: collectionProgressMap[book.id],
  collectionDepthText: collectionDepthMap[book.id],
}));
---

<Base
  title="我的阅读"
  description="集中查看当前浏览器里的继续阅读、最近足迹、书签与阅读设置。"
  pagefindIgnore={true}
>
  <div class="container">
    <header class="page-header reading-page-header">
      <h1 class="page-title">我的阅读</h1>
      <p class="page-subtitle">
        一个回访页，把继续阅读、最近书签、最近足迹和阅读设置都收拢到一起，回来就能马上接着读。
      </p>
    </header>

    <section class="section reading-return-section">
      <div class="section-head">
        <div>
          <h2 class="section-title">继续读馆藏更深的书</h2>
          <p class="section-sub">
            如果你只是想回来继续深读，先看这三本当前最适合长线追读的镇馆主力。
          </p>
        </div>
      </div>

      <div class="hall-card-grid">
        {deepReadingBooks.map((book) => (
          <article class="hall-card guide-card reading-return-card">
            <h3 class="hall-card-title">{book.data.title}</h3>
            <p class="hall-card-desc">{book.data.summary}</p>
            <p class="guide-card-meta">
              {collectionProgressMap[book.id] ?? '馆藏进度整理中'}
            </p>
            {collectionStatusMap[book.id] && (
              <p class="guide-card-meta">{collectionStatusMap[book.id]}</p>
            )}
            <p class="guide-card-meta">
              {collectionDepthMap[book.id] ?? '连读深度整理中'}
            </p>
            <div class="reading-return-actions">
              <a href={`/book/${book.id}`} class="btn btn-secondary guide-card-link">回到书页</a>
              <a
                href={buildEpubDownloadPath(book.id)}
                class="btn btn-secondary guide-card-link"
                download
              >
                下载 EPUB
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <ReadingDashboard bookMetaList={bookMetaList} />
  </div>
</Base>

<style>
  .reading-page-header {
    padding-top: 1.5rem;
  }

  .reading-return-section {
    margin-bottom: 1.5rem;
  }

  .reading-return-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .reading-return-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
  }
</style>
