---
import { getCollection } from 'astro:content';
import CuratedShelf from '../components/CuratedShelf.astro';
import FeatureCallout from '../components/FeatureCallout.astro';
import {
  homeEntryGuideSteps,
  homeInterestEntries,
  homeLibraryMap,
} from '../data/library/entry-guides';
import Base from '../layouts/Base.astro';
import {
  buildBookCollectionMaps,
  buildBookDisplayMaps,
  getBookCollectionStats,
  getLibraryCollectionStats,
  pickBooksByCategory,
  pickPlannedBooks,
  sortBooksByPlan,
} from '../lib/library';
import { buildEpubDownloadPath } from '../lib/epub';

const books = await getCollection('books');
const chapters = await getCollection('chapters');
const sortedBooks = sortBooksByPlan(books);

// 首页先只展示已经落库的书，避免出现空链接。
const curatorPicks = pickPlannedBooks(sortedBooks, ['hongloumeng', 'sanguoyanyi']);
const mustReadBooks = pickPlannedBooks(sortedBooks, [
  'hongloumeng',
  'sanguoyanyi',
  'xiyouji',
  'shuihuzhuan',
]);
const historyBooks = pickBooksByCategory(sortedBooks, 'historical-romance');
const strangeBooks = pickBooksByCategory(sortedBooks, 'strange-tales');
const worldlyBooks = pickBooksByCategory(sortedBooks, 'worldly-novels');
const proseBooks = pickBooksByCategory(sortedBooks, 'classical-prose');
const recentBooks = [...sortedBooks].reverse().slice(0, 3);
const { tierLabelMap, completionLevelMap } = buildBookDisplayMaps(sortedBooks);
const { collectionProgressMap, collectionDepthMap, collectionStatusMap } = buildBookCollectionMaps(sortedBooks, chapters);
const collectionStats = getLibraryCollectionStats(sortedBooks, chapters);
const coreProgressBooks = pickPlannedBooks(sortedBooks, ['hongloumeng', 'sanguoyanyi', 'xiyouji'])
  .map((book) => ({
    book,
    stats: getBookCollectionStats(book.id, chapters),
  }));

// 统计数据
const totalBooks = collectionStats.bookCount;
const totalChapters = collectionStats.collectedChapterCount;
const totalWords = collectionStats.collectedWordCount;
const totalWordsText = totalWords >= 10000
  ? `${(totalWords / 10000).toFixed(1)}万`
  : `${totalWords}`;
const strongestCoreDepth = Math.max(
  0,
  ...coreProgressBooks.map((item) => item.stats.continuousChapterCount),
);
---

<Base
  title="墨潮读书"
  description="墨潮读书——阅读经典，品味千年文脉。收录中国古典文学公版书籍，免费在线阅读。"
>
  <section class="library-hero">
    <div class="container library-hero-grid">
      <div class="library-hero-copy">
        <p class="hero-kicker">古典综合馆</p>
        <h1 class="hero-title">一间可以逛起来的免费小型读书馆</h1>
        <p class="hero-desc">
          墨潮读书正在从几本 demo 书，扩成一个有馆藏结构、有分馆入口、也能顺着专题一路读下去的小型古典书馆。
        </p>

        <div class="library-stat-grid">
          <div class="stat">
            <strong>{totalBooks}</strong>
            <span>已收录书籍</span>
          </div>
          <div class="stat">
            <strong>{totalChapters}</strong>
            <span>已整理章节</span>
          </div>
          <div class="stat">
            <strong>{totalWordsText}</strong>
            <span>已整理正文</span>
          </div>
        </div>

        <div class="hero-actions">
          <a href="#must-read" class="btn btn-primary">先逛名著必读</a>
          <a href="/search" class="btn btn-secondary">直接搜书</a>
        </div>
      </div>

      <FeatureCallout
        eyebrow="馆长推荐"
        title="先从镇馆书读起"
        description="这一轮先把核心名著做深，保证新读者第一次进站就能看见能读、能逛、能继续追下去的馆藏。"
        href={curatorPicks[0] ? `/book/${curatorPicks[0].id}` : '/search'}
        ctaLabel={curatorPicks[0] ? `先看《${curatorPicks[0].data.title}》` : '去搜索'}
        meta={`本轮优先：核心三书当前已可连续读到第 ${strongestCoreDepth} 章`}
      />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">核心馆藏进展</h2>
          <p class="section-sub">先把最能留住回访读者的三本主力长篇补厚，书页、章节页和 EPUB 会一起同步扩深。</p>
        </div>
      </div>

      <div class="hall-card-grid core-progress-grid">
        {coreProgressBooks.map(({ book, stats }) => (
          <article class="hall-card guide-card core-progress-card">
            <h3 class="hall-card-title">{book.data.title}</h3>
            <p class="hall-card-desc">{book.data.summary}</p>
            <p class="guide-card-meta">
              已收录 {stats.collectedChapterCount} / {book.data.chapterCount} 章，当前已整理到第 {stats.latestChapterNumber} 章。
            </p>
            <p class="guide-card-meta">
              可连续读到第 {stats.continuousChapterCount} 章，已整理正文约
              {' '}
              {stats.collectedWordCount >= 10000
                ? `${(stats.collectedWordCount / 10000).toFixed(1)} 万字`
                : `${stats.collectedWordCount} 字`}
              。
            </p>
            {collectionStatusMap[book.id] && (
              <p class="guide-card-meta">{collectionStatusMap[book.id]}</p>
            )}
            <div class="core-progress-actions">
              <a href={`/book/${book.id}`} class="btn btn-secondary guide-card-link">看书页</a>
              <a href={buildEpubDownloadPath(book.id)} class="btn btn-secondary guide-card-link" download>下 EPUB</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">怎么逛这座小馆</h2>
          <p class="section-sub">第一次来不用急着搜，先按最适合自己的进入方式选一个入口。</p>
        </div>
      </div>

      <div class="hall-card-grid">
        {homeEntryGuideSteps.map((guide) => (
          <article class="hall-card guide-card">
            <h3 class="hall-card-title">{guide.title}</h3>
            <p class="hall-card-desc">{guide.description}</p>
            {guide.meta && <p class="guide-card-meta">{guide.meta}</p>}
            <a href={guide.href} class="btn btn-secondary guide-card-link">{guide.ctaLabel}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">按兴趣进入</h2>
          <p class="section-sub">如果你更确定自己喜欢什么，就直接按题材和读法挑入口。</p>
        </div>
      </div>

      <div class="hall-card-grid">
        {homeInterestEntries.map((entry) => (
          <article class="hall-card guide-card">
            <h3 class="hall-card-title">{entry.title}</h3>
            <p class="hall-card-desc">{entry.description}</p>
            {entry.meta && <p class="guide-card-meta">{entry.meta}</p>}
            <a href={entry.href} class="btn btn-secondary guide-card-link">{entry.ctaLabel}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">馆藏地图</h2>
          <p class="section-sub">本站现在有四种主要入口：镇馆、分馆、专题和作者展架。</p>
        </div>
      </div>

      <div class="hall-card-grid">
        {homeLibraryMap.map((entry) => (
          <article class="hall-card guide-card">
            <h3 class="hall-card-title">{entry.title}</h3>
            <p class="hall-card-desc">{entry.description}</p>
            {entry.meta && <p class="guide-card-meta">{entry.meta}</p>}
            <a href={entry.href} class="btn btn-secondary guide-card-link">{entry.ctaLabel}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CuratedShelf
    title="馆长推荐"
    description="优先展示已经具备阅读深度的镇馆入口。"
    books={curatorPicks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="馆长推荐书架正在整理中。"
  />

  <div id="must-read">
    <CuratedShelf
      title="名著必读"
      description="先把最能代表本站气质的经典摆出来。"
      books={mustReadBooks}
      showCompletion={true}
      tierLabelMap={tierLabelMap}
      completionLevelMap={completionLevelMap}
      collectionStatusMap={collectionStatusMap}
      collectionProgressMap={collectionProgressMap}
      collectionDepthMap={collectionDepthMap}
      emptyText="名著必读书架正在补书。"
    />
  </div>

  <CuratedShelf
    title="历史演义"
    description="从大战略与人物群像切入，适合一口气读下去。"
    books={historyBooks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="历史演义分馆正在继续补书。"
  />

  <CuratedShelf
    title="志怪传奇"
    description="短篇、奇闻、夜读感，是后续专题页最有策展感的一组。"
    books={strangeBooks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="志怪传奇书架正在补齐《聊斋志异》等重点馆藏。"
  />

  <CuratedShelf
    title="世情小说"
    description="家族、士林与市井人情，是本站最厚的一条阅读线。"
    books={worldlyBooks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="世情小说书架会随着《金瓶梅》《儒林外史》一起扩进来。"
  />

  <CuratedShelf
    title="古文入门"
    description="留一个非小说入口，让网站更像馆，不只像小说列表。"
    books={proseBooks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="古文入门区将由《古文观止》率先补齐。"
  />

  <CuratedShelf
    title="最近入藏"
    description="先看最近补进馆里的书，方便回访读者快速逛新内容。"
    books={recentBooks}
    showCompletion={true}
    tierLabelMap={tierLabelMap}
    completionLevelMap={completionLevelMap}
    collectionStatusMap={collectionStatusMap}
    collectionProgressMap={collectionProgressMap}
    collectionDepthMap={collectionDepthMap}
    emptyText="最近入藏书架正在更新。"
  />
</Base>

<style>
  .core-progress-grid {
    align-items: stretch;
  }

  .core-progress-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .core-progress-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
</style>
