---
import Base from '../layouts/Base.astro';
---

<Base
  title="页面未找到"
  description="您访问的页面不存在，请返回首页继续浏览。"
>
  <div class="container">
    <div class="error-page">
      <div class="error-icon" aria-hidden="true">卷</div>
      <h1 class="error-code">404</h1>
      <h2 class="error-title">此页不见了</h2>
      <p class="error-desc">
        您访问的页面不存在，可能已被删除或地址有误。<br />
        就像失传的古籍，有些东西可能已无处寻觅。
      </p>
      <div class="error-actions">
        <a href="/" class="btn-primary">返回首页</a>
        <a href="/search" class="btn-secondary">搜索书目</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .error-page {
    text-align: center;
    padding: 5rem 1rem 4rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .error-icon {
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    font-size: 4rem;
    color: var(--paper-300, #e8dbc3);
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .error-code {
    font-size: 5rem;
    font-weight: 800;
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    color: var(--accent-500, #cc5c2f);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .error-title {
    font-family: var(--font-serif, 'Noto Serif SC', serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink-900, #18130f);
    margin-bottom: 1rem;
  }

  .error-desc {
    font-size: 0.95rem;
    color: var(--ink-500, #5f5044);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.65em 1.75em;
    background: var(--accent-500, #cc5c2f);
    color: #fff;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-600, #a44723);
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.65em 1.75em;
    background: var(--paper-200, #f1e8d8);
    color: var(--ink-700, #2a201a);
    border: 1px solid var(--paper-300, #e8dbc3);
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-secondary:hover {
    background: var(--paper-300, #e8dbc3);
    text-decoration: none;
  }
</style>
