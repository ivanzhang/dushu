---
/**
 * ChapterNav.astro — 章节导航组件
 * 显示"上一章"/"下一章"按钮和"返回目录"链接。
 * 首章无上一章，末章无下一章。
 */

interface Props {
  bookSlug: string;
  currentChapter: number;
  totalChapters: number;
  prevSlug?: string;
  nextSlug?: string;
}

const {
  bookSlug,
  currentChapter,
  totalChapters,
  prevSlug,
  nextSlug,
} = Astro.props;

const isFirst = currentChapter <= 1 || !prevSlug;
const isLast = currentChapter >= totalChapters || !nextSlug;

const prevHref = !isFirst && prevSlug ? `/book/${bookSlug}/${prevSlug}` : undefined;
const nextHref = !isLast && nextSlug ? `/book/${bookSlug}/${nextSlug}` : undefined;
const catalogHref = `/book/${bookSlug}`;
---

<nav class="chapter-nav" aria-label="章节导航">
  <!-- 上一章 -->
  {prevHref
    ? (
      <a href={prevHref} class="btn btn-secondary" rel="prev">
        ‹ 上一章
      </a>
    )
    : (
      <span class="btn btn-secondary chapter-nav-disabled" aria-disabled="true">
        ‹ 上一章
      </span>
    )
  }

  <!-- 返回目录 + 进度提示 -->
  <div class="chapter-nav-center">
    <a href={catalogHref} class="btn btn-secondary">返回目录</a>
    <p class="chapter-nav-progress">
      第 {currentChapter} 章 / 共 {totalChapters} 章
    </p>
  </div>

  <!-- 下一章 -->
  {nextHref
    ? (
      <a href={nextHref} class="btn btn-secondary" rel="next">
        下一章 ›
      </a>
    )
    : (
      <span class="btn btn-secondary chapter-nav-disabled" aria-disabled="true">
        下一章 ›
      </span>
    )
  }
</nav>

<style>
  .chapter-nav-disabled {
    opacity: 0.4;
    pointer-events: none;
    cursor: default;
  }

  .chapter-nav-progress {
    margin: 6px 0 0;
    font-size: 12px;
    color: var(--ink-300);
    text-align: center;
  }
</style>
