---
/**
 * ReadingDashboard.astro
 * 聚合当前浏览器里的继续阅读、书签、历史与阅读设置。
 *
 * 使用示例：
 * <ReadingDashboard bookMetaList={bookMetaList} />
 */

interface ReadingBookMeta {
  slug: string;
  title: string;
  author: string;
  summary: string;
  wordCount: number;
  completionLevel?: 'L1' | 'L2' | 'L3' | 'L4';
  tierLabel?: string;
  collectionStatusText?: string;
  collectionProgressText?: string;
  collectionDepthText?: string;
}

interface Props {
  bookMetaList: ReadingBookMeta[];
}

const { bookMetaList } = Astro.props;
---

<section class="reading-guide-card reading-dashboard" data-reading-dashboard>
  <script
    type="application/json"
    data-reading-book-meta
    set:html={JSON.stringify(bookMetaList)}
  ></script>

  <div class="reading-dashboard-head">
    <div>
      <h2 class="section-title">我的阅读</h2>
      <p class="section-sub">
        把当前浏览器里的继续阅读、书签和最近足迹集中在一起，方便回来时直接接着读。
      </p>
    </div>

    <div class="reading-dashboard-actions">
      <a href="/search" class="btn btn-secondary">继续找书</a>
      <a href="/category" class="btn btn-secondary">去逛分馆</a>
    </div>
  </div>

  <p class="notice reading-dashboard-notice">
    阅读记录保存在当前浏览器，本机可持续回看；如果换设备或清空浏览器数据，需要重新积累。
  </p>
  <p class="reading-dashboard-manage-note">
    在读书卡里也能清空这本记录，书签和足迹都支持逐条移除；如果只是想把样式调回初始状态，也可以恢复默认设置。
  </p>

  <div class="reading-dashboard-grid">
    <section class="panel reading-panel">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">继续阅读中的书</strong>
          <p class="reading-panel-sub">按最近保存进度排序，可直接回到章节继续阅读；不想保留时也能清空这本记录。</p>
        </div>
      </div>
      <div class="panel-body">
        <div class="reading-active-grid" data-active-books>
          <article class="reading-empty-card">
            <h3>还没有开始读书</h3>
            <p>先从镇馆书或分馆入口挑一本到第一章，之后这里就会自动出现继续阅读入口。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="panel reading-panel">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">最近书签</strong>
          <p class="reading-panel-sub">看到想回来的位置时保存书签，这里会自动汇总，也支持逐条移除。</p>
        </div>
      </div>
      <div class="panel-body">
        <ul class="reading-log-list" data-bookmark-list>
          <li class="reader-empty">还没有书签，读到喜欢的位置时再记一下。</li>
        </ul>
      </div>
    </section>

    <section class="panel reading-panel">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">最近足迹</strong>
          <p class="reading-panel-sub">最近打开过的章节会记录在这里，方便回看刚读过什么，也支持逐条移除。</p>
        </div>
      </div>
      <div class="panel-body">
        <ul class="reading-log-list" data-history-list>
          <li class="reader-empty">还没有最近阅读记录。</li>
        </ul>
      </div>
    </section>

    <section class="panel reading-panel">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">当前阅读设置</strong>
          <p class="reading-panel-sub">会同步显示你最近一次阅读时用的字号、行距、版心和主题。</p>
        </div>
      </div>
      <div class="panel-body">
        <dl class="reading-settings-grid" data-settings-list>
          <div class="reading-setting-item">
            <dt>字体大小</dt>
            <dd>20 px</dd>
          </div>
          <div class="reading-setting-item">
            <dt>行距</dt>
            <dd>1.9</dd>
          </div>
          <div class="reading-setting-item">
            <dt>版心宽度</dt>
            <dd>760 px</dd>
          </div>
          <div class="reading-setting-item">
            <dt>阅读主题</dt>
            <dd>默认主题</dd>
          </div>
        </dl>
        <div class="reading-settings-actions">
          <button type="button" class="btn btn-secondary btn-sm" data-reader-settings-reset>
            恢复默认设置
          </button>
        </div>
      </div>
    </section>

    <section class="panel reading-panel reading-panel-backup">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">阅读记录备份</strong>
          <p class="reading-panel-sub">把当前浏览器里的进度、书签、足迹和阅读设置导出成备份，换设备时再导回来。</p>
        </div>
      </div>
      <div class="panel-body">
        <div class="reading-backup-actions">
          <button type="button" class="btn btn-secondary" data-reader-export>
            导出阅读记录
          </button>
          <button type="button" class="btn btn-secondary" data-reader-import-trigger>
            导入备份文件
          </button>
          <input type="file" accept=".json,application/json" data-reader-import-input hidden />
        </div>
        <p class="reading-backup-note">
          导入时会把备份和当前浏览器里的记录合并，较新的进度会优先保留，不必担心把刚读到的位置冲掉。
        </p>
        <p class="reading-backup-status" data-reader-status>
          建议在换设备前先导出一次，文件会保存为 JSON，可随时留档。
        </p>
      </div>
    </section>

    <section class="panel reading-panel reading-panel-bulk-manage">
      <div class="panel-head reading-panel-head">
        <div>
          <strong class="reading-panel-title">批量整理阅读记录</strong>
          <p class="reading-panel-sub">当你想整体归档当前浏览器里的阅读痕迹时，可以一键清空足迹、书签，或整套阅读记录。</p>
        </div>
      </div>
      <div class="panel-body">
        <div class="reading-bulk-actions">
          <button type="button" class="btn btn-secondary" data-reader-clear-history>
            清空全部足迹
          </button>
          <button type="button" class="btn btn-secondary" data-reader-clear-bookmarks>
            清空全部书签
          </button>
          <button type="button" class="btn btn-secondary" data-reader-clear-records>
            清空全部阅读记录
          </button>
        </div>
        <p class="reading-bulk-note">
          清空全部阅读记录时会保留当前阅读设置，方便你重整书架后继续沿用熟悉的字号、行距和主题。
        </p>
        <p class="reading-backup-status" data-reader-status>
          如果只是想整理某一本到某一章，也可以继续使用上面的逐条移除和单本清空。
        </p>
      </div>
    </section>
  </div>
</section>

<script>
  import { buildEpubDownloadPath } from '../lib/epub';
  import {
    clearAllBookmarks,
    clearAllHistory,
    clearAllReadingRecords,
    clearBookReadingState,
    removeBookmarkEntry,
    removeHistoryEntry,
    READER_STORAGE_KEY,
    buildChapterHref,
    formatProgressLabel,
    getReadingDashboardSnapshot,
    mergeReaderStates,
    parseReaderState,
    resetReaderSettings,
    serializeReaderState,
  } from '../lib/reader-state';

  interface ReadingBookMeta {
    slug: string;
    title: string;
    author: string;
    summary: string;
    wordCount: number;
    completionLevel?: 'L1' | 'L2' | 'L3' | 'L4';
    tierLabel?: string;
    collectionStatusText?: string;
    collectionProgressText?: string;
    collectionDepthText?: string;
  }

  const root = document.querySelector<HTMLElement>('[data-reading-dashboard]');

  if (root) {
    const bookMetaNode = root.querySelector<HTMLScriptElement>('[data-reading-book-meta]');
    const activeBooksRoot = root.querySelector<HTMLElement>('[data-active-books]');
    const bookmarkList = root.querySelector<HTMLElement>('[data-bookmark-list]');
    const historyList = root.querySelector<HTMLElement>('[data-history-list]');
    const settingsList = root.querySelector<HTMLElement>('[data-settings-list]');
    const exportButton = root.querySelector<HTMLButtonElement>('[data-reader-export]');
    const importTrigger = root.querySelector<HTMLButtonElement>('[data-reader-import-trigger]');
    const importInput = root.querySelector<HTMLInputElement>('[data-reader-import-input]');
    const statusNodes = root.querySelectorAll<HTMLElement>('[data-reader-status]');
    const resetSettingsButton = root.querySelector<HTMLButtonElement>('[data-reader-settings-reset]');
    const clearHistoryButton = root.querySelector<HTMLButtonElement>('[data-reader-clear-history]');
    const clearBookmarksButton = root.querySelector<HTMLButtonElement>('[data-reader-clear-bookmarks]');
    const clearRecordsButton = root.querySelector<HTMLButtonElement>('[data-reader-clear-records]');

    const bookMetaList = JSON.parse(bookMetaNode?.textContent ?? '[]') as ReadingBookMeta[];
    const bookMetaMap = new Map(bookMetaList.map((item) => [item.slug, item]));

    function formatWordCount(wordCount: number) {
      if (wordCount >= 10000) {
        return `${(wordCount / 10000).toFixed(1)} 万字`;
      }

      return `${wordCount} 字`;
    }

    function formatThemeLabel(theme: string) {
      if (theme === 'sepia') {
        return '护眼主题';
      }

      if (theme === 'dark') {
        return '夜间主题';
      }

      return '默认主题';
    }

    function setBackupStatus(message: string, tone: 'neutral' | 'success' | 'error' = 'neutral') {
      if (statusNodes.length === 0) {
        return;
      }

      statusNodes.forEach((node) => {
        node.dataset.tone = tone;
        node.textContent = message;
      });
    }

    function getBookMeta(bookSlug: string, fallbackTitle: string) {
      return bookMetaMap.get(bookSlug) ?? {
        slug: bookSlug,
        title: fallbackTitle,
        author: '馆内作品',
        summary: '该书的书目数据正在整理中，可以先从阅读记录直接继续阅读。',
        wordCount: 0,
      };
    }

    function createActionLink(href: string, text: string, secondary = false) {
      const link = document.createElement('a');
      link.href = href;
      link.className = secondary ? 'btn btn-secondary btn-sm' : 'btn btn-primary btn-sm';
      link.textContent = text;
      return link;
    }

    function createActionButton(text: string) {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'btn btn-secondary btn-sm';
      button.textContent = text;
      return button;
    }

    function persistDashboardState(nextState: ReturnType<typeof parseReaderState>, message: string) {
      localStorage.setItem(READER_STORAGE_KEY, serializeReaderState(nextState));
      renderDashboard();
      setBackupStatus(message, 'success');
    }

    // 批量整理动作统一走同一套确认、落盘和反馈，避免三处逻辑各自漂移。
    function runBulkCleanup(options: {
      confirmText: string;
      emptyMessage: string;
      successMessage: string;
      hasData: (state: ReturnType<typeof parseReaderState>) => boolean;
      transform: (state: ReturnType<typeof parseReaderState>) => ReturnType<typeof parseReaderState>;
    }) {
      const currentState = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));

      if (!options.hasData(currentState)) {
        setBackupStatus(options.emptyMessage);
        return;
      }

      if (!window.confirm(options.confirmText)) {
        return;
      }

      const nextState = options.transform(currentState);
      persistDashboardState(nextState, options.successMessage);
    }

    function renderActiveBooks(items: ReturnType<typeof getReadingDashboardSnapshot>['activeBooks']) {
      if (!activeBooksRoot) {
        return;
      }

      activeBooksRoot.replaceChildren();

      if (items.length === 0) {
        const emptyCard = document.createElement('article');
        const title = document.createElement('h3');
        const desc = document.createElement('p');

        emptyCard.className = 'reading-empty-card';
        title.textContent = '还没有开始读书';
        desc.textContent = '先从四大名著、分馆书架或搜索页挑一本到第一章，之后这里就会自动出现继续阅读入口。';

        emptyCard.append(title, desc);
        activeBooksRoot.append(emptyCard);
        return;
      }

      items.slice(0, 6).forEach((item) => {
        const meta = getBookMeta(item.bookSlug, item.bookTitle);
        const card = document.createElement('article');
        const badgeRow = document.createElement('div');
        const title = document.createElement('h3');
        const metaText = document.createElement('p');
        const desc = document.createElement('p');
        const collection = document.createElement('p');
        const collectionStatus = document.createElement('p');
        const progress = document.createElement('p');
        const detail = document.createElement('p');
        const actions = document.createElement('div');
        const clearButton = createActionButton('清空这本记录');

        card.className = 'reading-book-card';
        badgeRow.className = 'reading-book-badges';
        title.className = 'reading-book-title';
        metaText.className = 'reading-book-meta';
        desc.className = 'reading-book-desc';
        collectionStatus.className = 'reading-book-status';
        collection.className = 'reading-book-collection';
        progress.className = 'reading-book-progress';
        detail.className = 'reading-book-detail';
        actions.className = 'reading-book-actions';

        if (meta.tierLabel) {
          const tier = document.createElement('span');
          tier.className = 'tag tag-tier';
          tier.textContent = meta.tierLabel;
          badgeRow.append(tier);
        }

        if (meta.completionLevel) {
          const completion = document.createElement('span');
          completion.className = 'tag';
          completion.textContent = `${meta.completionLevel} 阅读深度`;
          badgeRow.append(completion);
        }

        title.textContent = meta.title;
        metaText.textContent = `${meta.author} · ${formatWordCount(meta.wordCount)}`;
        desc.textContent = meta.summary;
        collectionStatus.textContent = meta.collectionStatusText ?? '';
        collection.textContent = [meta.collectionProgressText, meta.collectionDepthText]
          .filter(Boolean)
          .join(' · ');
        progress.textContent = `读到第 ${item.chapterNumber} 章 · ${formatProgressLabel(item.progress)}`;
        detail.textContent = `最近足迹 ${item.historyCount} 条 · 书签 ${item.bookmarkCount} 条`;

        actions.append(
          createActionLink(buildChapterHref(item.bookSlug, item.chapterSlug), '继续阅读'),
          createActionLink(`/book/${item.bookSlug}`, '回到书页', true),
          createActionLink(buildEpubDownloadPath(item.bookSlug), '下载 EPUB', true),
          clearButton,
        );

        clearButton.addEventListener('click', () => {
          const confirmed = window.confirm(`确定清空《${meta.title}》的阅读进度、最近足迹和书签吗？`);
          if (!confirmed) {
            return;
          }

          const currentState = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
          const nextState = clearBookReadingState(currentState, item.bookSlug);
          persistDashboardState(nextState, `已清空《${meta.title}》的阅读记录。`);
        });

        const cardChildren = [badgeRow, title, metaText, desc] as HTMLElement[];
        if (collectionStatus.textContent) {
          cardChildren.push(collectionStatus);
        }
        if (collection.textContent) {
          cardChildren.push(collection);
        }
        cardChildren.push(progress, detail, actions);

        card.append(...cardChildren);
        activeBooksRoot.append(card);
      });
    }

    // 历史与书签共用一套渲染器，统一保持章节入口和百分比信息。
    function renderLogList(
      target: HTMLElement | null,
      items: Array<{
        bookSlug: string;
        bookTitle: string;
        chapterSlug: string;
        chapterTitle: string;
        chapterNumber: number;
        progress: number;
      }>,
      emptyText: string,
      kind: 'bookmark' | 'history',
    ) {
      if (!target) {
        return;
      }

      target.replaceChildren();

      if (items.length === 0) {
        const empty = document.createElement('li');
        empty.className = 'reader-empty';
        empty.textContent = emptyText;
        target.append(empty);
        return;
      }

      items.slice(0, 8).forEach((item) => {
        const listItem = document.createElement('li');
        const content = document.createElement('div');
        const link = document.createElement('a');
        const sub = document.createElement('p');
        const meta = document.createElement('span');
        const actions = document.createElement('div');
        const removeButton = createActionButton(kind === 'bookmark' ? '移除书签' : '移除足迹');

        listItem.className = 'reading-log-item';
        content.className = 'reading-log-content';
        link.className = 'reader-link-item';
        sub.className = 'reading-log-sub';
        meta.className = 'reader-link-meta';
        actions.className = 'reading-log-actions';

        link.href = buildChapterHref(item.bookSlug, item.chapterSlug);
        link.textContent = `${item.bookTitle} · 第 ${item.chapterNumber} 章`;
        sub.textContent = item.chapterTitle;
        meta.textContent = formatProgressLabel(item.progress);

        removeButton.addEventListener('click', () => {
          const currentState = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
          const nextState = kind === 'bookmark'
            ? removeBookmarkEntry(currentState, item.bookSlug, item.chapterSlug)
            : removeHistoryEntry(currentState, item.bookSlug, item.chapterSlug);

          persistDashboardState(
            nextState,
            kind === 'bookmark'
              ? `已移除《${item.bookTitle}》第 ${item.chapterNumber} 章的书签。`
              : `已移除《${item.bookTitle}》第 ${item.chapterNumber} 章的足迹。`,
          );
        });

        content.append(link, sub);
        actions.append(meta, removeButton);
        listItem.append(content, actions);
        target.append(listItem);
      });
    }

    function renderSettings(settings: ReturnType<typeof getReadingDashboardSnapshot>['settings']) {
      if (!settingsList) {
        return;
      }

      settingsList.replaceChildren();

      const settingEntries = [
        ['字体大小', `${settings.fontSize} px`],
        ['行距', settings.lineHeight.toFixed(1)],
        ['版心宽度', `${settings.contentWidth} px`],
        ['阅读主题', formatThemeLabel(settings.theme)],
      ];

      settingEntries.forEach(([label, value]) => {
        const wrapper = document.createElement('div');
        const term = document.createElement('dt');
        const definition = document.createElement('dd');

        wrapper.className = 'reading-setting-item';
        term.textContent = label;
        definition.textContent = value;

        wrapper.append(term, definition);
        settingsList.append(wrapper);
      });
    }

    function renderDashboard() {
      const state = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
      const snapshot = getReadingDashboardSnapshot(state);

      renderActiveBooks(snapshot.activeBooks);
      renderLogList(bookmarkList, snapshot.recentBookmarks, '还没有书签，读到喜欢的位置时再记一下。', 'bookmark');
      renderLogList(historyList, snapshot.recentHistory, '还没有最近阅读记录。', 'history');
      renderSettings(snapshot.settings);
    }

    function exportReaderBackup() {
      const state = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
      const today = new Date().toISOString().slice(0, 10);
      const blob = new Blob([serializeReaderState(state)], {
        type: 'application/json;charset=utf-8',
      });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');

      link.href = url;
      link.download = `mochao-reader-backup-${today}.json`;
      link.click();

      window.setTimeout(() => URL.revokeObjectURL(url), 0);
      setBackupStatus('已导出当前浏览器里的阅读记录，可把这个 JSON 带到别的设备导入。', 'success');
    }

    async function importReaderBackup(file: File) {
      const raw = await file.text();

      try {
        JSON.parse(raw);
      } catch {
        setBackupStatus('导入失败：这个文件不是合法的 JSON 备份。', 'error');
        return;
      }

      const importedState = parseReaderState(raw);
      const hasReaderRecords = Object.keys(importedState.progress).length > 0
        || importedState.history.length > 0
        || importedState.bookmarks.length > 0;

      if (!hasReaderRecords) {
        setBackupStatus('导入取消：备份里没有可用的进度、书签或最近阅读记录。', 'error');
        return;
      }

      const currentState = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
      const mergedState = mergeReaderStates(currentState, importedState);

      localStorage.setItem(READER_STORAGE_KEY, serializeReaderState(mergedState));
      renderDashboard();
      setBackupStatus('已合并导入备份，较新的进度会优先保留到当前浏览器。', 'success');
    }

    renderDashboard();

    exportButton?.addEventListener('click', exportReaderBackup);
    importTrigger?.addEventListener('click', () => {
      importInput?.click();
    });
    importInput?.addEventListener('change', async () => {
      const file = importInput.files?.[0];
      importInput.value = '';

      if (!file) {
        return;
      }

      await importReaderBackup(file);
    });
    resetSettingsButton?.addEventListener('click', () => {
      const currentState = parseReaderState(localStorage.getItem(READER_STORAGE_KEY));
      const nextState = resetReaderSettings(currentState);
      persistDashboardState(nextState, '已把阅读设置恢复为默认值。');
    });
    clearHistoryButton?.addEventListener('click', () => {
      runBulkCleanup({
        confirmText: '确定清空全部最近足迹吗？',
        emptyMessage: '当前还没有可清空的足迹记录。',
        successMessage: '已清空全部足迹。',
        hasData: (state) => state.history.length > 0,
        transform: (state) => clearAllHistory(state),
      });
    });
    clearBookmarksButton?.addEventListener('click', () => {
      runBulkCleanup({
        confirmText: '确定清空全部书签吗？',
        emptyMessage: '当前还没有可清空的书签。',
        successMessage: '已清空全部书签。',
        hasData: (state) => state.bookmarks.length > 0,
        transform: (state) => clearAllBookmarks(state),
      });
    });
    clearRecordsButton?.addEventListener('click', () => {
      runBulkCleanup({
        confirmText: '确定清空全部阅读记录吗？这会移除继续阅读、最近足迹和书签，但会保留当前阅读设置。',
        emptyMessage: '当前还没有可清空的阅读记录。',
        successMessage: '已清空全部阅读记录，并保留当前阅读设置。',
        hasData: (state) => {
          return Object.keys(state.progress).length > 0
            || state.history.length > 0
            || state.bookmarks.length > 0;
        },
        transform: (state) => clearAllReadingRecords(state),
      });
    });

    window.addEventListener('storage', (event) => {
      if (event.key === READER_STORAGE_KEY) {
        renderDashboard();
      }
    });
  }
</script>

